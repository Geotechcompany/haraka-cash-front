# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
# Quote keys if they contain special characters.
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=harakacash

# Custom auth page URLs (match src/routes)
CLERK_SIGN_IN_URL=/login
CLERK_SIGN_UP_URL=/register
CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# SMPLY Pay — M-Pesa gateway (get base URL + paths from SMPLY Pay support/dashboard)
SMPLY_PAY_API_KEY=your_api_key_here
SMPLY_PAY_CLIENT_ID=your_client_id_here
# Wallet / project code from SMPLY Pay dashboard (projectCode on STK + B2C)
SMPLY_PAY_PROJECT_CODE=WLT-CD-1MRWANZ
# api.smplypay.com does not resolve; use the host SMPLY Pay gave you (often https://smplypay.com)
SMPLY_PAY_API_BASE=https://smplypay.com
# Auth: client-id (client_id + api_key headers, SMPLY default) | bearer | raw | api-key
SMPLY_PAY_AUTH_STYLE=client-id
# Optional path overrides — live API confirmed on smplypay.com (Jul 2026)
# STK collect:  /api/v1/provider-one/externalstk
# Withdraw B2C: /api/v1/provider-one/externalb2c
# Wallet balance: GET /api/v1/provider-one/wallet/{walletCode}/balance
# {projectCode} is replaced with SMPLY_PAY_PROJECT_CODE (e.g. WLT-CD-1MRWANZ)
SMPLY_PAY_WALLET_PATH=/api/v1/provider-one/wallet/{projectCode}/balance
SMPLY_PAY_STK_PATH=/api/v1/provider-one/externalstk
# SMPLY_PAY_STK_URL=https://smplypay.com/api/v1/provider-one/externalstk
SMPLY_PAY_WITHDRAW_PATH=/api/v1/provider-one/externalb2c
# Public URL for STK/webhook callbacks (use ngrok tunnel for local testing)
APP_URL=http://localhost:3000
# Client-visible site URL for canonical/OG tags (set in production)
VITE_APP_URL=http://localhost:3000
# Production (Netlify): APP_URL=https://harakacash.netlify.app
#
# Netlify environment variables (Site settings → Environment variables):
#   CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY, VITE_CLERK_PUBLISHABLE_KEY
#   MONGODB_URI (e.g. MongoDB Atlas connection string), MONGODB_DB
#   APP_URL=https://harakacash.netlify.app
#   VITE_APP_URL=https://harakacash.netlify.app
#   CLERK_SIGN_IN_URL=/login, CLERK_SIGN_UP_URL=/register
#   CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
#   CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# Optional (M-Pesa): SMPLY_PAY_API_KEY, SMPLY_PAY_CLIENT_ID, SMPLY_PAY_API_BASE, etc.

# Quote AI notes (server only; never VITE_*)
# Admin → Settings can override keys and pick provider: auto | gemini | openai | nvidia | off
# Auto order: Gemini → OpenAI → NVIDIA (first resolved key that succeeds; else deterministic-only)
#
# Gemini resolution: Admin key → GEMINI_API_KEY → GOOGLE_GENERATIVE_AI_API_KEY
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
#
# OpenAI resolution: Admin key → OPENAI_API_KEY
OPENAI_API_KEY=
#
# NVIDIA NIM (OpenAI-compatible): Admin key → NVIDIA_API_KEY
# Default base: https://integrate.api.nvidia.com/v1
# Default model: meta/llama-3.1-8b-instruct
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
